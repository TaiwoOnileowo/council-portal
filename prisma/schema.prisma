generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  VENDOR
}

enum Level {
  L100
  L200
  L300
  L400
  L500
}

enum TransactionType {
  TOP_UP
  PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String   @unique
  matricNumber String   @unique
  department   String
  level        Level
  passwordHash String?
  role         Role     @default(STUDENT)
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  wallet       Wallet?
  bookings     Booking[]
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Int           @default(0) // stored in kobo (smallest unit)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          String            @id @default(uuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Int               // in kobo
  description String
  ref         String            @unique
  createdAt   DateTime          @default(now())
}

enum PriceListDirection {
  LEAVING
  RETURNING
}

enum AvailabilityType {
  ACTIVE
  INACTIVE
  SCHEDULED
}

model Vendor {
  id            String      @id @default(uuid())
  firstName     String
  lastName      String
  email         String      @unique
  phone         String?      @unique
  passwordHash  String
  transportName String
  image         String?
  tagline       String?
  description   String?
  tiktok        String?
  instagram     String?
  bankCode      String?
  bankName      String?
  accountNumber String?
  accountName   String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  priceLists    PriceList[]
  bookings      Booking[]
}

model PriceList {
  id            String             @id @default(uuid())
  vendorId      String
  vendor        Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name          String
  direction     PriceListDirection
  luggagePolicy String             @default("")
  notes         String             @default("")
  availType     AvailabilityType   @default(ACTIVE)
  schedStart    DateTime?
  schedEnd      DateTime?
  routes        PriceListRoute[]
  departureTimes DepartureTime[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([vendorId, direction])
}

model PriceListRoute {
  id          String    @id @default(uuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  name        String
  price       Int       // in naira
  capacity    Int?      // null = unlimited
  active      Boolean   @default(true)
  bookings    Booking[]
}

model DepartureTime {
  id          String    @id @default(uuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  day         String
  time        String    // "HH:MM" 24hr format
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  FAILED
}

model Booking {
  id             String             @id @default(uuid())
  reference      String             @unique // our tx_ref passed to Flutterwave
  flwRef         String?            // Flutterwave's internal flw_ref
  status         BookingStatus      @default(CONFIRMED)

  // Passenger snapshot
  passengerName  String
  passengerPhone String
  parentsPhone   String
  hall           String
  roomNumber     String

  // Route snapshot (preserved even if route is edited/deleted)
  direction      PriceListDirection
  routeName      String
  fare           Int                // naira
  serviceFee     Int                // naira
  studentNotes   String?            // optional note from student to vendor

  // Relations
  userId         String?
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  vendorId       String
  vendor         Vendor             @relation(fields: [vendorId], references: [id])
  routeId        String
  route          PriceListRoute     @relation(fields: [routeId], references: [id])

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}
