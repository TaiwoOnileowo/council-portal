generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  VENDOR
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String   @unique
  matricNumber String   @unique
  passwordHash String?
  role         Role     @default(STUDENT)
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
