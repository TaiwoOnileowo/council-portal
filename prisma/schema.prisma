generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  VENDOR
}

enum VendorCategory {
  TRANSPORT
}

enum Level {
  L100
  L200
  L300
  L400
  L500
}

enum PriceListDirection {
  LEAVING
  RETURNING
}

enum AvailabilityType {
  ACTIVE
  INACTIVE
  SCHEDULED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  FAILED
}

enum PayoutStatus {
  PENDING
  SUCCESS
  FAILED
}

model user {
  id              String           @id @default(uuid())
  first_name      String
  last_name       String
  email           String           @unique
  phone           String           @unique
  password_hash   String?
  role            Role             @default(STUDENT)
  image           String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  student_profile student_profile?
  vendor_profile  vendor_profile?
  admin_profile   admin_profile?
  wallet          wallet[] // append-only ledger entries
  bookings        booking[] // as passenger
  virtual_account virtual_account?
}

model app_setting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model admin_profile {
  user_id    String   @id
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())
}

model student_profile {
  user_id       String @id
  user          user   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  matric_number String @unique
  department    String
  level         Level
}

model vendor_profile {
  user_id         String           @id
  user            user             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category        VendorCategory   @default(TRANSPORT)
  business_name   String
  tagline         String?
  description     String?
  tiktok          String?
  instagram       String?
  bank_code       String?
  bank_name       String?
  account_number  String?
  account_name    String?
  is_active       Boolean          @default(true)
  price_lists     price_list[] // transport vertical
  bookings        booking[] // transport vertical — as provider
  wallet          wallet[] // vendor earnings & payout ledger entries
  payouts         payout[]
  virtual_account virtual_account?
}

model wallet {
  id                String          @id @default(uuid())
  // Exactly one of user_id / vendor_id is set per entry.
  user_id           String? // set on STUDENT entries; null on vendor entries
  user              user?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vendor_id         String? // set on VENDOR entries (earnings, payouts); null on student entries
  vendor            vendor_profile? @relation(fields: [vendor_id], references: [user_id], onDelete: Cascade)
  balance           Int // running balance in kobo, after this entry is applied
  difference        Int // signed delta in kobo applied by this entry
  currency          String          @default("NGN")
  reason            String // free-text, e.g. "Wallet top-up", "Transport booking — Daniel Hall"
  type              String? // category, e.g. "topup", "booking", "refund"
  model_responsible String? // originating model, e.g. "Payment", "Booking", "Refund"
  model_id          String? // id of the originating record
  reference         String?         @unique // idempotency key (Flutterwave tx_ref, booking reference)
  domain            String          @default("live")
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  @@index([user_id, created_at])
  @@index([vendor_id, created_at])
}

model virtual_account {
  id             String          @id @default(uuid())
  // Exactly one of user_id / vendor_id is set per account.
  user_id        String?         @unique // set for STUDENT accounts
  user           user?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vendor_id      String?         @unique // set for VENDOR accounts
  vendor         vendor_profile? @relation(fields: [vendor_id], references: [user_id], onDelete: Cascade)
  provider       String          @default("flutterwave")
  account_number String
  bank_name      String
  bank_code      String?
  tx_ref         String          @unique // reference supplied at (re)provisioning; Flutterwave echoes it back on every inbound transfer to this account
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
}

model payout {
  id        String         @id @default(uuid())
  reference String         @unique // our transfer reference passed to Flutterwave
  vendor_id String
  vendor    vendor_profile @relation(fields: [vendor_id], references: [user_id], onDelete: Cascade)
  amount    Int // payout amount in kobo
  status    PayoutStatus   @default(PENDING)

  bank_code      String
  bank_name      String
  account_number String
  account_name   String

  transfer_id    String?
  failure_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vendor_id, created_at])
}

model price_list {
  id                String             @id @default(uuid())
  vendor_id         String
  vendor            vendor_profile     @relation(fields: [vendor_id], references: [user_id], onDelete: Cascade)
  name              String
  direction         PriceListDirection
  luggage_policy    String             @default("")
  notes             String             @default("")
  availability_type AvailabilityType   @default(ACTIVE)
  scheduled_start   DateTime?
  scheduled_end     DateTime?
  routes            price_list_route[]
  departure_times   departure_time[]
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  @@unique([vendor_id, direction])
}

model price_list_route {
  id            String     @id @default(uuid())
  price_list_id String
  price_list    price_list @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  name          String
  price         Int // in naira
  capacity      Int? // null = unlimited
  active        Boolean    @default(true)
  bookings      booking[]
}

model departure_time {
  id            String     @id @default(uuid())
  price_list_id String
  price_list    price_list @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  departs_at    DateTime // specific departure date and time
}

model booking {
  id        String        @id @default(uuid())
  reference String        @unique // our tx_ref passed to Flutterwave
  flw_ref   String? // Flutterwave's internal flw_ref
  status    BookingStatus @default(CONFIRMED)

  // Passenger snapshot
  passenger_name  String
  passenger_phone String
  parents_phone   String
  hall            String
  room_number     String

  // Route snapshot (preserved even if route is edited/deleted)
  direction           PriceListDirection
  route_name          String
  fare                Int // naira
  service_fee         Int // naira — customer-facing fee, currently always 0
  commission          Int                @default(0) // naira — platform's cut, taken from the vendor's side
  student_notes       String? // optional note from student to vendor
  destination_address String? // student's off-campus drop-off / pickup address
  departure_at        DateTime? // snapshot of the departure the student chose

  // Relations
  user_id   String?
  user      user?            @relation(fields: [user_id], references: [id], onDelete: SetNull)
  vendor_id String
  vendor    vendor_profile   @relation(fields: [vendor_id], references: [user_id])
  route_id  String
  route     price_list_route @relation(fields: [route_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vendor_id, status, created_at])
  @@index([vendor_id, route_name])
  @@index([user_id, created_at])
}
